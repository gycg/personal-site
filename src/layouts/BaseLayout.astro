---
import '../styles/global.css';
import BackToTop from '../components/BackToTop.astro';
import { DEFAULT_OG_IMAGE, MAIN_NAV_ITEMS, SITE_AUTHOR, SITE_DESCRIPTION, SITE_TITLE, SITE_URL } from '../consts';

interface Props {
  title?: string;
  description?: string;
  type?: 'website' | 'article';
  canonicalPath?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  type = 'website',
  canonicalPath = Astro.url.pathname,
  ogImage = DEFAULT_OG_IMAGE,
  jsonLd = [],
} = Astro.props;

const pageTitle = title === SITE_TITLE ? SITE_TITLE : `${title} | ${SITE_TITLE}`;
const canonicalUrl = new URL(canonicalPath, SITE_URL).toString();
const ogImageUrl = new URL(ogImage, SITE_URL).toString();
const rssUrl = new URL('/rss.xml', SITE_URL).toString();
const pathname = Astro.url.pathname;
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE_TITLE,
    description: SITE_DESCRIPTION,
    url: SITE_URL,
    inLanguage: 'zh-CN',
    publisher: {
      '@type': 'Person',
      name: SITE_AUTHOR,
    },
    potentialAction: {
      '@type': 'SearchAction',
      target: new URL('/search/?q={search_term_string}', SITE_URL).toString(),
      'query-input': 'required name=search_term_string',
    },
  },
  ...(Array.isArray(jsonLd) ? jsonLd : [jsonLd]),
];

function isActiveNav(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&family=Noto+Sans+SC:wght@400;500;600;700&family=Noto+Serif+SC:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={SITE_AUTHOR} />
    <meta name="theme-color" content="#f0f4ef" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title={`${SITE_TITLE} RSS`} href={new URL('/rss.xml', SITE_URL).toString()} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={SITE_TITLE} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={`${SITE_TITLE} 文章分享图`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">跳到正文</a>
    {type === 'article' && <div class="reading-progress" aria-hidden="true"><span></span></div>}
    <header class="site-header">
      <div class="site-shell nav">
        <a class="brand" href="/" aria-label={`${SITE_TITLE} 首页`}>{SITE_TITLE}</a>
        <nav class="nav-links" aria-label="主导航">
          {
            MAIN_NAV_ITEMS.map((item) => (
              <a href={item.href} aria-current={isActiveNav(item.href) ? 'page' : undefined}>
                {item.label}
              </a>
            ))
          }
        </nav>
        <nav class="utility-links" aria-label="工具入口">
          <a href="/search/" aria-current={pathname.startsWith('/search/') ? 'page' : undefined}>搜索</a>
          <details class="rss-menu">
            <summary>RSS</summary>
            <div class="rss-menu-panel">
              <a href="/rss.xml">打开 RSS</a>
              <button type="button" data-copy-rss={rssUrl}>复制订阅地址</button>
              <p data-rss-copy-status aria-live="polite">复制后粘贴到 RSS 阅读器。</p>
            </div>
          </details>
          <a href="/about/#contact">反馈</a>
        </nav>
      </div>
    </header>
    <main id="main-content" class="site-shell" tabindex="-1">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-shell">
        <p>© {new Date().getFullYear()} {SITE_AUTHOR}. Built with Astro.</p>
        <nav aria-label="页脚导航">
          <a href="/rss.xml">RSS</a>
          <a href="/search/">搜索</a>
          <a href="/about/#method">研究方法</a>
          <a href="/about/#contact">联系</a>
        </nav>
      </div>
    </footer>
    <BackToTop />
    <script is:inline>
      document.querySelectorAll('.prose img').forEach((image) => {
        image.loading = image.loading || 'lazy';
        image.decoding = image.decoding || 'async';
      });

      const rssCopyButton = document.querySelector('[data-copy-rss]');
      const rssCopyStatus = document.querySelector('[data-rss-copy-status]');
      const copyText = async (value) => {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(value);
          return;
        }

        const input = document.createElement('textarea');
        input.value = value;
        input.setAttribute('readonly', '');
        input.style.position = 'fixed';
        input.style.opacity = '0';
        document.body.append(input);
        input.select();
        document.execCommand('copy');
        input.remove();
      };

      rssCopyButton?.addEventListener('click', async () => {
        try {
          await copyText(rssCopyButton.dataset.copyRss);
          if (rssCopyStatus) rssCopyStatus.textContent = '已复制 RSS 订阅地址。';
        } catch {
          if (rssCopyStatus) rssCopyStatus.textContent = '复制失败，可以点“打开 RSS”后复制地址栏。';
        }
      });
    </script>
    {
      type === 'article' && (
        <>
          <script async src="https://busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js" />
          <script is:inline>
            const progressBar = document.querySelector('.reading-progress span');
            const updateReadingProgress = () => {
              if (!progressBar) return;
              const scrollable = document.documentElement.scrollHeight - window.innerHeight;
              const progress = scrollable > 0 ? Math.min(window.scrollY / scrollable, 1) : 0;
              progressBar.style.transform = 'scaleX(' + progress + ')';
            };
            updateReadingProgress();
            window.addEventListener('scroll', updateReadingProgress, { passive: true });
            window.addEventListener('resize', updateReadingProgress);
          </script>
        </>
      )
    }
  </body>
</html>
