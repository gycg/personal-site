---
import '../styles/global.css';
import { SITE_AUTHOR, SITE_DESCRIPTION, SITE_TITLE, SITE_URL } from '../consts';

interface Props {
  title?: string;
  description?: string;
  type?: 'website' | 'article';
  canonicalPath?: string;
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  type = 'website',
  canonicalPath = Astro.url.pathname,
} = Astro.props;

const pageTitle = title === SITE_TITLE ? SITE_TITLE : `${title} | ${SITE_TITLE}`;
const canonicalUrl = new URL(canonicalPath, SITE_URL).toString();
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={SITE_AUTHOR} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={SITE_TITLE} />
    <meta name="twitter:card" content="summary" />
  </head>
  <body>
    <header class="site-header">
      <div class="site-shell nav">
        <a class="brand" href="/">{SITE_TITLE}</a>
        <nav class="nav-links" aria-label="主导航">
          <a href="/posts/">文章</a>
          <a href="/about/">关于</a>
        </nav>
      </div>
    </header>
    <main class="site-shell">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-shell">
        <p>© {new Date().getFullYear()} {SITE_AUTHOR}. Built with Astro.</p>
      </div>
    </footer>
  </body>
</html>
