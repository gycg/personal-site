---
import '../styles/global.css';
import BackToTop from '../components/BackToTop.astro';
import { SITE_AUTHOR, SITE_DESCRIPTION, SITE_TITLE, SITE_URL } from '../consts';

interface Props {
  title?: string;
  description?: string;
  type?: 'website' | 'article';
  canonicalPath?: string;
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  type = 'website',
  canonicalPath = Astro.url.pathname,
} = Astro.props;

const pageTitle = title === SITE_TITLE ? SITE_TITLE : `${title} | ${SITE_TITLE}`;
const canonicalUrl = new URL(canonicalPath, SITE_URL).toString();
const pathname = Astro.url.pathname;

const navItems = [
  { href: '/posts/', label: '文章' },
  { href: '/categories/', label: '分类' },
  { href: '/method/', label: '方法' },
  { href: '/projects/', label: '项目' },
  { href: '/about/', label: '关于' },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&family=Noto+Sans+SC:wght@400;500;600;700&family=Noto+Serif+SC:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={SITE_AUTHOR} />
    <meta name="theme-color" content="#f0f4ef" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title={`${SITE_TITLE} RSS`} href={new URL('/rss.xml', SITE_URL).toString()} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={SITE_TITLE} />
    <meta name="twitter:card" content="summary" />
  </head>
  <body>
    <header class="site-header">
      <div class="site-shell nav">
        <a class="brand" href="/">{SITE_TITLE}</a>
        <nav class="nav-links" aria-label="主导航">
          {
            navItems.map((item) => (
              <a href={item.href} aria-current={pathname.startsWith(item.href) ? 'page' : undefined}>
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>
    <main class="site-shell">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-shell">
        <p>© {new Date().getFullYear()} {SITE_AUTHOR}. Built with Astro.</p>
        <nav class="footer-links" aria-label="页脚链接">
          <a href="/method/">研究方法</a>
          <a href="/series/stock-basics/">从零看懂股票</a>
          <a href="/rss.xml">RSS</a>
        </nav>
      </div>
    </footer>
    <BackToTop />
    {
      type === 'article' && (
        <script async src="https://busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js" />
      )
    }
  </body>
</html>
