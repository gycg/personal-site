---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageSidebar from '../../components/PageSidebar.astro';
import { getPostUrl } from '../../lib/posts';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const tags = Array.from(new Set(posts.flatMap((post) => post.data.tags))).sort();

const dateFormatter = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title="文章" description="按时间排列的全部博客文章。" canonicalPath="/posts/">
  <div class="page-grid">
    <div>
      <section class="hero">
        <p class="eyebrow">文章</p>
        <h1>按时间或主题浏览</h1>
        <p class="lead">这里按时间归档，也保留主题入口。内容会慢一点，但会尽量把过程、依据和结论都写完整。</p>
      </section>

      <ul class="post-list">
        {
          posts.map((post) => (
            <li class="post-card">
              <p class="post-meta">{dateFormatter.format(post.data.pubDate)}</p>
              <h2><a href={getPostUrl(post)}>{post.data.title}</a></h2>
              <p>{post.data.description}</p>
              <div class="tags">
                {post.data.tags.map((tag) => <a class="tag" href={`/tags/${tag}/`}>{tag}</a>)}
              </div>
            </li>
          ))
        }
      </ul>
    </div>

    <PageSidebar
      title="浏览方式"
      intro="文章页保留最直接的两种用法：顺着时间看，或者直接按主题筛。"
      sections={[
        {
          title: '按主题',
          items: tags.map((tag) => ({
            label: tag,
            href: `/tags/${tag}/`,
            text: `查看与 ${tag} 相关的文章。`,
          })),
        },
        {
          title: '相关页面',
          items: [
            { label: '分类页', href: '/categories/', text: '从分类入口快速找到同类内容。' },
            { label: '项目页', href: '/projects/', text: '如果想先看成型内容，可以直接去项目页。' },
          ],
        },
      ]}
    />
  </div>
</BaseLayout>
