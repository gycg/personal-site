---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageSidebar from '../../components/PageSidebar.astro';
import { compareSeriesPosts, estimateReadingMinutes, getPostUrl } from '../../lib/posts';

const posts = (await getCollection('posts', ({ data }) => {
  return !data.draft && data.tags.includes('从零看懂股票');
})).sort(compareSeriesPosts);

const dateFormatter = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title="从零看懂股票"
  description="写给普通人的股票入门路径，从股票是什么开始，逐步理解市场、财报与估值。"
  canonicalPath="/series/stock-basics/"
>
  <div class="page-grid">
    <div>
      <section class="hero">
        <p class="eyebrow">专题</p>
        <h1>从零看懂股票</h1>
        <p class="lead">按顺序阅读这组文章，先建立基本概念，再进入行情、收益、财报和估值。目前已发布 {posts.length} 篇。</p>
      </section>

      <ol class="series-path">
        {
          posts.map((post, index) => (
            <li class="series-step">
              <span class="series-step-number">{String(index + 1).padStart(2, '0')}</span>
              <div>
                <p class="post-meta">{dateFormatter.format(post.data.pubDate)} · 约 {estimateReadingMinutes(post)} 分钟读完</p>
                <h2><a href={getPostUrl(post)}>{post.data.title}</a></h2>
                <p>{post.data.description}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>

    <PageSidebar
      title="专题"
      intro="先搭框架，再看公司。"
      sections={[
        {
          title: '继续阅读',
          items: [
            { label: '全部文章', href: '/posts/' },
            { label: '研究方法', href: '/about/#method' },
            { label: 'RSS 订阅', href: '/rss.xml' },
          ],
        },
      ]}
    />
  </div>
</BaseLayout>
