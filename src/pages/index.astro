---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION } from '../consts';
import PageSidebar from '../components/PageSidebar.astro';
import { getPostUrl } from '../lib/posts';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
const dateFormatter = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout description={SITE_DESCRIPTION}>
  <div class="page-grid home-grid">
    <div class="main-column">
      <section class="hero">
        <p class="eyebrow">长坡厚雪</p>
        <h1>一个大厂程序员的长期投资研究笔记</h1>
        <p class="lead">
          用工程化方法研究股票、公司和 AI 投研工具。这里不荐股，不喊单，专注沉淀可复盘的研究过程、投资框架和通往财务自由的长期实验。
        </p>
      </section>

      <section class="content-section" aria-labelledby="reading-paths">
        <div class="section-head">
          <h2 id="reading-paths">阅读路径</h2>
        </div>
        <div class="path-grid">
          <a class="path-card" href="/series/stock-basics/">
            <span>入门</span>
            <strong>从零看懂股票</strong>
            <p>按顺序理解股票、行情、收益来源和基础概念。</p>
          </a>
          <a class="path-card" href="/tags/财报分析/">
            <span>研究</span>
            <strong>公司研究笔记</strong>
            <p>从财报、产业逻辑和跟踪指标看公司。</p>
          </a>
          <a class="path-card" href="/about/#method">
            <span>边界</span>
            <strong>研究方法</strong>
            <p>说明数据来源、风险声明和内容边界。</p>
          </a>
        </div>
      </section>

      <section class="content-section" aria-labelledby="latest-posts">
        <div class="section-head">
          <h2 id="latest-posts">最新文章</h2>
          <a href="/posts/">查看全部</a>
        </div>
        <ul class="post-list">
          {
            posts.map((post) => (
              <li class="post-card">
                <p class="post-meta">{dateFormatter.format(post.data.pubDate)}</p>
                <h3><a href={getPostUrl(post)}>{post.data.title}</a></h3>
                <p>{post.data.description}</p>
                <div class="tags">
                  {post.data.tags.map((tag) => <a class="tag" href={`/tags/${tag}/`}>{tag}</a>)}
                </div>
              </li>
            ))
          }
        </ul>
      </section>
    </div>

    <PageSidebar
      title="研究方向"
      compact
      intro="股票、公司研究、AI 投研工具，以及普通人如何长期积累资产。"
      sections={[
        {
          title: '入口',
          items: [
            { label: '文章归档', href: '/posts/' },
            { label: '专题浏览', href: '/series/' },
            { label: '从零看懂股票', href: '/series/stock-basics/' },
            { label: '研究方法', href: '/about/#method' },
            { label: '项目页', href: '/projects/' },
            { label: '关于页', href: '/about/' },
          ],
        },
        {
          title: '最近更新',
          items: posts.slice(0, 1).map((post) => ({
            label: post.data.title,
            href: getPostUrl(post),
          })),
        },
      ]}
    />
  </div>
</BaseLayout>
