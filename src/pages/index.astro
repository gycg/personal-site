---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION } from '../consts';
import { getPostUrl } from '../lib/posts';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const tags = Array.from(new Set(posts.flatMap((post) => post.data.tags))).sort();
const dateFormatter = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout description={SITE_DESCRIPTION}>
  <section class="hero">
    <p class="eyebrow">中文个人博客</p>
    <h1>写给长期维护的技术与生活记录。</h1>
    <p class="lead">
      这里记录项目实践、工具选择、阅读笔记和一些可复用的经验。页面保持简单，重点放在内容的清晰度和可读性上。
    </p>
  </section>

  <section aria-labelledby="latest-posts">
    <div class="section-head">
      <h2 id="latest-posts">最新文章</h2>
      <a href="/posts/">查看全部</a>
    </div>
    <ul class="post-list">
      {
        posts.map((post) => (
          <li class="post-card">
            <p class="post-meta">{dateFormatter.format(post.data.pubDate)}</p>
            <h3><a href={getPostUrl(post)}>{post.data.title}</a></h3>
            <p>{post.data.description}</p>
            <div class="tags">
              {post.data.tags.map((tag) => <a class="tag" href={`/tags/${tag}/`}>{tag}</a>)}
            </div>
          </li>
        ))
      }
    </ul>
  </section>

  <section aria-labelledby="tags">
    <h2 id="tags">标签</h2>
    <div class="tag-cloud">
      {tags.map((tag) => <a class="tag" href={`/tags/${tag}/`}>{tag}</a>)}
    </div>
  </section>
</BaseLayout>
