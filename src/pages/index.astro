---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION } from '../consts';
import PageSidebar from '../components/PageSidebar.astro';
import { getPostUrl } from '../lib/posts';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const tags = Array.from(new Set(posts.flatMap((post) => post.data.tags))).sort();
const dateFormatter = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout description={SITE_DESCRIPTION}>
  <div class="page-grid">
    <div>
      <section class="hero">
        <p class="eyebrow">首页</p>
        <h1>长坡厚雪，主要做 AI、炒股，以及 AI + 炒股方向研究。</h1>
        <p class="lead">
          这里放的是持续更新的研究记录、建站过程、项目整理和一些值得反复回看的判断框架。
        </p>
      </section>

      <section aria-labelledby="latest-posts">
        <div class="section-head">
          <h2 id="latest-posts">最新文章</h2>
          <a href="/posts/">查看全部</a>
        </div>
        <ul class="post-list">
          {
            posts.map((post) => (
              <li class="post-card">
                <p class="post-meta">{dateFormatter.format(post.data.pubDate)}</p>
                <h3><a href={getPostUrl(post)}>{post.data.title}</a></h3>
                <p>{post.data.description}</p>
                <div class="tags">
                  {post.data.tags.map((tag) => <a class="tag" href={`/tags/${tag}/`}>{tag}</a>)}
                </div>
              </li>
            ))
          }
        </ul>
      </section>

      <section aria-labelledby="featured-content">
        <div class="section-head">
          <h2 id="featured-content">精选内容</h2>
        </div>
        <ul class="post-list">
          {
            posts.slice(0, 2).map((post) => (
              <li class="post-card">
                <h3><a href={getPostUrl(post)}>{post.data.title}</a></h3>
                <p>{post.data.description}</p>
              </li>
            ))
          }
        </ul>
      </section>
    </div>

    <PageSidebar
      title="右侧导航"
      intro="首页把重点内容收在右边，方便先认识作者，再决定从文章、分类还是项目开始看。"
      sections={[
        {
          title: '快速入口',
          items: [
            { label: '文章归档', href: '/posts/' },
            { label: '分类浏览', href: '/categories/' },
            { label: '项目展示', href: '/projects/' },
            { label: '关于作者', href: '/about/' },
          ],
        },
        {
          title: '研究主题',
          items: tags.map((tag) => ({
            label: tag,
            href: `/tags/${tag}/`,
          })),
        },
      ]}
    />
  </div>
</BaseLayout>
