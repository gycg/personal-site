---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageSidebar from '../../components/PageSidebar.astro';
import { projects } from '../../data/projects';
---

<BaseLayout title="项目" description="投研工具、内容工作流和长期写作系统。" canonicalPath="/projects/">
  <div class="page-grid">
    <div>
      <section class="hero">
        <p class="eyebrow">项目</p>
        <h1>工具、流程和长期系统</h1>
        <p class="lead">这里展示围绕投资研究、AI 工作流和内容生产搭建的项目。部分项目仍在进行中，会随着文章和工具一起迭代。</p>
      </section>

      <section class="project-list" aria-label="项目列表">
        {
          projects.map((project) => (
            <article class="project-card">
              {project.image && (
                <img
                  src={project.image.src}
                  alt={project.image.alt}
                  width="1200"
                  height="720"
                  loading="lazy"
                />
              )}
              <div class="project-copy">
                <p class="post-meta">{project.eyebrow}</p>
                <h2>{project.title}</h2>
                <p>{project.description}</p>
                {project.meta && (
                  <div class="project-meta-grid">
                    {project.meta.map((item) => (
                      <div>
                        <span>{item.label}</span>
                        <strong>{item.value}</strong>
                      </div>
                    ))}
                  </div>
                )}
                {project.links && (
                  <div class="project-links">
                    {project.links.map((link) => <a class="tag" href={link.href}>{link.label}</a>)}
                  </div>
                )}
              </div>
            </article>
          ))
        }
      </section>

      <section class="content-section" aria-labelledby="project-notes">
        <div class="section-head">
          <h2 id="project-notes">项目说明</h2>
        </div>
        <div class="project-note-grid">
          <article class="project-note">
            <span>方向</span>
            <p>用最少的依赖做一个长期可维护的中文个人博客。</p>
          </article>
          <article class="project-note">
            <span>目标</span>
            <p>把文章、项目和个人介绍整理成同一套公开入口。</p>
          </article>
          <article class="project-note">
            <span>下一步</span>
            <p>继续补充研究系统、AI 工作流和可公开展示的工具截图。</p>
          </article>
        </div>
      </section>
    </div>

    <PageSidebar
      title="项目"
      sections={[
        {
          title: '相关页面',
          items: [
            { label: '首页', href: '/' },
            { label: '文章页', href: '/posts/' },
            { label: '我的持仓（模拟）', href: '/projects/holdings/' },
            { label: '恐慌指数', href: '/projects/fear-index/' },
            { label: '研究方法', href: '/about/#method' },
            { label: '关于页', href: '/about/' },
          ],
        },
      ]}
    />
  </div>
</BaseLayout>
