---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageSidebar from '../../components/PageSidebar.astro';

const posts = await getCollection('posts', ({ data }) => !data.draft);
const categories = Array.from(new Set(posts.flatMap((post) => post.data.tags)))
  .sort()
  .map((tag) => ({
    tag,
    count: posts.filter((post) => post.data.tags.includes(tag)).length,
  }));
---

<BaseLayout title="分类" description="按主题快速找到同类内容。" canonicalPath="/categories/">
  <div class="page-grid">
    <div>
      <section class="hero">
        <p class="eyebrow">分类</p>
        <h1>方便用户快速找到同类内容</h1>
      </section>

      <ul class="post-list">
        {
          categories.map((category) => (
            <li class="post-card">
              <h2><a href={`/tags/${category.tag}/`}>#{category.tag}</a></h2>
              <p>{category.count} 篇内容，适合按同一主题连续阅读。</p>
            </li>
          ))
        }
      </ul>
    </div>

    <PageSidebar
      title="入口"
      sections={[
        {
          title: '页面入口',
          items: [
            { label: '首页', href: '/' },
            { label: '文章页', href: '/posts/' },
            { label: '项目页', href: '/projects/' },
          ],
        },
      ]}
    />
  </div>
</BaseLayout>
