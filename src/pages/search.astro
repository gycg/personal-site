---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts', ({ data }) => !data.draft);
const tags = Array.from(new Set(posts.flatMap((post) => post.data.tags))).sort();
---

<BaseLayout title="站内搜索" description="搜索长坡厚雪已经发布的文章。" canonicalPath="/search/">
  <section class="hero">
    <p class="eyebrow">搜索</p>
    <h1>站内搜索</h1>
    <p class="lead">按标题、摘要和标签搜索文章。</p>
  </section>

  <section class="search-panel" aria-labelledby="search-title">
    <h2 id="search-title">搜索文章</h2>
    <label class="search-box">
      <span>关键词</span>
      <input id="search-input" type="search" placeholder="例如：财报分析、股票收益、AI 算力" autocomplete="off" />
    </label>
    <p id="search-status" class="post-meta">输入关键词开始搜索。</p>
    <div class="search-suggestions" aria-label="常用标签">
      {tags.map((tag) => <button type="button" data-search-tag={tag}>{tag}</button>)}
    </div>
    <ul id="search-results" class="post-list" aria-live="polite"></ul>
  </section>

  <script is:inline>
    const input = document.querySelector('#search-input');
    const results = document.querySelector('#search-results');
    const status = document.querySelector('#search-status');
    const tagButtons = document.querySelectorAll('[data-search-tag]');
    let posts = [];
    let urlTimer;

    const normalize = (value) => value.toLowerCase().trim();
    const formatDate = (value) => new Intl.DateTimeFormat('zh-CN', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    }).format(new Date(value));
    const updateUrl = (query) => {
      clearTimeout(urlTimer);
      urlTimer = setTimeout(() => {
        const url = new URL(window.location.href);
        if (query) url.searchParams.set('q', query);
        else url.searchParams.delete('q');
        window.history.replaceState({}, '', url);
      }, 180);
    };
    const appendHighlightedText = (node, value, tokens) => {
      const lowerValue = value.toLowerCase();
      let cursor = 0;
      const ranges = tokens
        .map((token) => {
          const index = lowerValue.indexOf(token);
          return index >= 0 ? { start: index, end: index + token.length } : null;
        })
        .filter(Boolean)
        .sort((a, b) => a.start - b.start);

      for (const range of ranges) {
        if (range.start < cursor) continue;
        if (range.start > cursor) node.append(document.createTextNode(value.slice(cursor, range.start)));
        const mark = document.createElement('mark');
        mark.className = 'search-result-mark';
        mark.textContent = value.slice(range.start, range.end);
        node.append(mark);
        cursor = range.end;
      }
      if (cursor < value.length) node.append(document.createTextNode(value.slice(cursor)));
    };

    const renderResults = (items, query) => {
      results.innerHTML = '';
      if (!query) {
        status.textContent = '输入关键词开始搜索。';
        return;
      }
      const tokens = query.split(/\s+/).filter(Boolean);
      status.textContent = items.length ? '找到 ' + items.length + ' 篇文章。' : '没有找到匹配文章，可以换用更短的关键词或点击标签浏览。';
      for (const post of items) {
        const item = document.createElement('li');
        item.className = 'post-card';
        const meta = document.createElement('p');
        meta.className = 'post-meta';
        meta.textContent = formatDate(post.pubDate);
        const heading = document.createElement('h2');
        const link = document.createElement('a');
        link.href = post.url;
        appendHighlightedText(link, post.title, tokens);
        heading.append(link);
        const description = document.createElement('p');
        appendHighlightedText(description, post.description, tokens);
        const tagList = document.createElement('div');
        tagList.className = 'tags';
        for (const tag of post.tags) {
          const tagLink = document.createElement('a');
          tagLink.className = 'tag';
          tagLink.href = '/tags/' + encodeURIComponent(tag) + '/';
          appendHighlightedText(tagLink, tag, tokens);
          tagList.append(tagLink);
        }
        item.append(meta, heading, description, tagList);
        results.append(item);
      }
    };

    const search = () => {
      const query = normalize(input.value);
      const tokens = query.split(/\s+/).filter(Boolean);
      const matched = posts
        .map((post) => {
          const haystack = normalize([post.title, post.description, post.tags.join(' ')].join(' '));
          const score = tokens.reduce((total, token) => {
            if (normalize(post.title).includes(token)) return total + 4;
            if (post.tags.some((tag) => normalize(tag).includes(token))) return total + 3;
            if (haystack.includes(token)) return total + 1;
            return total;
          }, 0);
          return { post, score };
        })
        .filter((item) => item.score > 0)
        .sort((a, b) => b.score - a.score)
        .map((item) => item.post);

      renderResults(matched, query);
      updateUrl(query);
    };

    fetch('/search.json')
      .then((response) => response.json())
      .then((data) => {
        posts = data;
        input.addEventListener('input', search);
        tagButtons.forEach((button) => {
          button.addEventListener('click', () => {
            input.value = button.dataset.searchTag;
            input.focus();
            search();
          });
        });
        const params = new URLSearchParams(window.location.search);
        const initial = params.get('q');
        if (initial) {
          input.value = initial;
          search();
        }
      })
      .catch(() => {
        status.textContent = '搜索索引加载失败，请稍后再试。';
      });
  </script>
</BaseLayout>
